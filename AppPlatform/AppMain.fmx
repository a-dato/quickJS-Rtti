      object mmCustomersWeb: TMemo
        Touch.InteractiveGestures = [Pan, LongTap, DoubleTap]
        DataDetectorTypes = []
        Lines.Strings = (
          
            '// Be sure to run the synology drive node.js server in temp -> M' +
            'elvin'
          ''
          'CustomerType.Instance.InitCustomerStorage();'
          ''
          'function getProperty(type, name) {'
          '  for (const prop of app.Config.GetProperties(type)) {'
          '    if (String(prop.Name) === name) {'
          '      return prop;'
          '    }'
          '  }'
          ''
          '  return null;'
          '}'
          ''
          
            'function ensureProperty(type, name, displayName, valueType, desc' +
            'riptor) {'
          '  let prop = getProperty(type, name);'
          '  if (prop != null) {'
          '    return prop;'
          '  }'
          ''
          
            '  app.Config.AddProperty(type, name, displayName, valueType, des' +
            'criptor);'
          '  return getProperty(type, name);'
          '}'
          ''
          
            'const customerDescriptor = CustomerType.Instance.PropertyDescrip' +
            'tor.Customer;'
          'ensureProperty('
          '  IProject,'
          '  '#39'Customer'#39','
          '  '#39'Customer'#39','
          '  Customer,'
          '  customerDescriptor'
          ');'
          ''
          'const customers = [];'
          'for (const customer of app.Storage['#39'Customers'#39']) {'
          '  customers.push({'
          '    id: String(customer.ID),'
          '    name: String(customer.Name)'
          '  });'
          '}'
          ''
          'const projects = [];'
          'for (const project of app.Storage['#39'Projects'#39']) {'
          '  const customer = project.Customer;'
          ''
          '  projects.push({'
          '    id: String(project.ID),'
          '    description: String(project.Description),'
          
            '    customer: customer == null || customer === 0 || customer ===' +
            ' undefined'
          '      ? null'
          '      : {'
          '          id: String(customer.ID),'
          '          name: String(customer.Name)'
          '        }'
          '  });'
          '}'
          ''
          
            'const w = app.Environment.CreateWindow(IProject, app.Environment' +
            '.MainWindow);'
          'w.CreateFrame('#39'Persons'#39');'
          ''
          
            'w.Frame.Content.RegisterAction('#39'addCustomerToProject'#39', function(' +
            'projectIndex, customerIndex) {'
          '  function getProperty(type, name) {'
          '    for (const prop of app.Config.GetProperties(type)) {'
          '      if (String(prop.Name) === name) {'
          '        return prop;'
          '      }'
          '    }'
          ''
          '    return null;'
          '  }'
          ''
          '  const project = app.Storage['#39'Projects'#39'][projectIndex];'
          '  const customer = app.Storage['#39'Customers'#39'][customerIndex];'
          ''
          '  const customerProp = getProperty(IProject, '#39'Customer'#39');'
          '  if (customerProp == null) {'
          '    throw new Error(`Property '#39'Customer'#39' not found`);'
          '  }'
          ''
          '  customerProp.SetValue(project, customer, []);'
          ''
          '  console.log(`Customer is: ${project.Customer}`);'
          '}.toString());'
          ''
          'w.Show();'
          ''
          'w.Frame.Content.SetData(JSON.stringify({'
          '  title: '#39'Project Customers'#39','
          '  itemLabel: '#39'Project'#39','
          '  optionLabel: '#39'Customers'#39','
          '  projects,'
          '  customers'
          '}));')
        StyledSettings = [Size, Style, FontColor]
        TextSettings.Font.Family = 'Fira Code'
        Align = Client
        Size.Width = 1167.000000000000000000
        Size.Height = 362.000000000000000000
        Size.PlatformDefault = False
        TabOrder = 3
        Viewport.Width = 1147.000000000000000000
        Viewport.Height = 358.000000000000000000
      end
    end
